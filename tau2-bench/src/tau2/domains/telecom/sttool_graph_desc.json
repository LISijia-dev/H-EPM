{
  "nodes": [
    {
      "id": "disconnect_vpn",
      "desc": "Disconnects any active VPN (Virtual Private Network) connection. Stops routing your internet traffic through a VPN server, which might affect connection speed or access to content.",
      "parameters": []
    },
    {
      "id": "transfer_to_human_agents",
      "desc": "Transfer the user to a human agent, with a summary of the user's issue.",
      "parameters": [
        {
          "name": "summary",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "set_network_mode_preference",
      "desc": "Changes the type of cellular network your phone prefers to connect to (e.g., 5G, LTE/4G, 3G). Higher-speed networks (LTE/5G) provide faster data but may use more battery.",
      "parameters": [
        {
          "name": "mode",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "toggle_wifi_calling",
      "desc": "Toggles Wi-Fi Calling ON or OFF. This feature allows you to make and receive calls over Wi-Fi instead of the cellular network, which can help in areas with weak cellular signal.",
      "parameters": []
    },
    {
      "id": "toggle_data",
      "desc": "Toggles your phone's mobile data connection ON or OFF. Controls whether your phone can use cellular data for internet access when Wi-Fi is unavailable.",
      "parameters": []
    },
    {
      "id": "toggle_roaming",
      "desc": "Toggles Data Roaming ON or OFF. When ON, your phone can use data networks in areas outside your carrier's coverage.",
      "parameters": []
    },
    {
      "id": "reseat_sim_card",
      "desc": "Simulates removing and reinserting your SIM card. This can help resolve recognition issues.",
      "parameters": []
    },
    {
      "id": "grant_app_permission",
      "desc": "Gives a specific permission to an app (like access to storage, camera, or location). Required for some app functions to work properly.",
      "parameters": [
        {
          "name": "app_name",
          "type": "string",
          "desc": ""
        },
        {
          "name": "permission",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "enable_roaming",
      "desc": "Enables international roaming on a line.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "desc": ""
        },
        {
          "name": "line_id",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "resume_line",
      "desc": "Resumes a suspended line.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "desc": ""
        },
        {
          "name": "line_id",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "reset_apn_settings",
      "desc": "Resets your APN settings to the default settings.",
      "parameters": []
    },
    {
      "id": "toggle_data_saver_mode",
      "desc": "Toggles Data Saver mode ON or OFF. When ON, it reduces data usage, which may affect data speed.",
      "parameters": []
    },
    {
      "id": "refuel_data",
      "desc": "Refuels data for a specific line, adding to the customer's bill.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "desc": ""
        },
        {
          "name": "line_id",
          "type": "string",
          "desc": ""
        },
        {
          "name": "gb_amount",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "send_payment_request",
      "desc": "Sends a payment request to the customer for a specific bill.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "desc": ""
        },
        {
          "name": "bill_id",
          "type": "string",
          "desc": ""
        }
      ]
    },
    {
      "id": "toggle_airplane_mode",
      "desc": "Toggles Airplane Mode ON or OFF. When ON, it disconnects all wireless communications including cellular, Wi-Fi, and Bluetooth.",
      "parameters": []
    },
    {
      "id": "reboot_device",
      "desc": "Restarts your phone completely. This can help resolve many temporary software glitches by refreshing all running services and connections.",
      "parameters": []
    },
    {
      "id": "make_payment",
      "desc": "Makes a payment for the bill that the agent has sent you.",
      "parameters": []
    }
  ],
